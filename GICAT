    "RH": "https://www.dropbox.com/request/xu9l6kkjotmmceqr1p01",
    "Finance": "https://www.dropbox.com/request/qxlj24jolujvxf1nc93y",
    "Supply Chain": "https://www.dropbox.com/request/wkr6y806ghvzo0vnpubo",
    "Commerce & Management": "https://www.dropbox.com/request/1vnzpei3fetezj14hltq",
    "Data": "https://www.dropbox.com/request/8g5auaaki3cq3bfm9179",
    "IT & Développement web": "https://www.dropbox.com/request/zeyiwaasssqxulx4anqq",
    "Cybersécurité": "https://www.dropbox.com/request/q8telwnu856j14uunxyv"
  },
  "Toulouse": {
    "Communication & Marketing": "https://www.dropbox.com/request/ztmewfp5qszv8vo3fqw4",
    "RH": "https://www.dropbox.com/request/ncqs70jf5rdljpuehhgu",
    "Finance": "https://www.dropbox.com/request/n4k3w7pgx0pqqjejkeqw",
    "Supply Chain": "https://www.dropbox.com/request/v0kkidxbi9lmcn1q22gs",
    "Commerce & Management": "https://www.dropbox.com/request/41qyewr2vu4ql8724s2z",
    "Data": "https://www.dropbox.com/request/eqnat4hhw3plj81yu7ed",
    "IT & Développement web": "https://www.dropbox.com/request/oobx76fp0ljakn0bd8ry",
    "Cybersécurité": "https://www.dropbox.com/request/m6iu8rxw064a8trr67wi"
  },
  "Marseille": {
    "Communication & Marketing": "https://www.dropbox.com/request/pb0j0nidielg7wnujvxy",
    "RH": "https://www.dropbox.com/request/mckt31kxj06cqx497lct",
    "Finance": "https://www.dropbox.com/request/t1j645hn7imiq5wiowwd",
    "Supply Chain": "https://www.dropbox.com/request/b5dkvb7fmbpqqy9sd7tm",
    "Commerce & Management": "https://www.dropbox.com/request/ctn1m5enckmfrxq97vav",
    "Data": "https://www.dropbox.com/request/9ptzqjsdt2ur4mbtnd0q",
    "IT & Développement web": "https://www.dropbox.com/request/ja8rc1t0mzk3mqyujrq6",
    "Cybersécurité": "https://www.dropbox.com/request/pvwl7loozcmd6ik4o2jz"
  }
};

const icons = {
  "Communication & Marketing": '<svg viewBox="0 0 24 24"><path d="M18 8a3 3 0 0 1 0 6"/><path d="M10 8v11a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1v-5"/><path d="M12 8h0l4.524-3.77A.9.9 0 0 1 18 5v14a.9.9 0 0 1-1.476.692L12 16H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h8"/></svg>',
  "RH": '<svg viewBox="0 0 24 24"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.85"/></svg>',
  "Finance": '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><line x1="12" y1="8" x2="12" y2="12"/><path d="M12 16h.01"/><path d="M9.5 9.5a2.5 2.5 0 0 1 5 0c0 1.5-2.5 2-2.5 4"/></svg>',
  "Supply Chain": '<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
  "Commerce & Management": '<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>',
  "Data": '<svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  "IT & Développement web": '<svg viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  "Cybersécurité": '<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>'
};

const pinIcon = '<svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>';
const chevronIcon = '<svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';
const arrowIcon = '<svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';

const container = document.getElementById('campuses');

Object.entries(data).forEach(([campus, specs]) => {
  const block = document.createElement('div');
  block.className = 'campus-block';

  const header = document.createElement('div');
  header.className = 'campus-header';
  header.setAttribute('role', 'button');
  header.setAttribute('tabindex', '0');
  header.setAttribute('aria-expanded', 'false');
  header.innerHTML = `
    <div class="campus-left">
      <div class="campus-pin">${pinIcon}</div>
      <span class="campus-name">${campus}</span>
    </div>
    <div class="chevron">${chevronIcon}</div>
  `;

  const body = document.createElement('div');
  body.className = 'campus-body';

  const list = document.createElement('div');
  list.className = 'spec-list';

  Object.entries(specs).forEach(([spec, url]) => {
    const a = document.createElement('a');
    a.className = 'spec-btn';
    a.href = url;
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
    a.innerHTML = `
      <span class="spec-icon">${icons[spec] || icons['Data']}</span>
      <span class="spec-label">${spec}</span>
      <span class="spec-arrow">${arrowIcon}</span>
    `;
    list.appendChild(a);
  });

  body.appendChild(list);

  const toggle = () => {
    const isOpen = body.classList.contains('open');
    document.querySelectorAll('.campus-body.open').forEach(b => b.classList.remove('open'));
    document.querySelectorAll('.chevron.open').forEach(c => c.classList.remove('open'));
    document.querySelectorAll('.campus-header').forEach(h => h.setAttribute('aria-expanded', 'false'));
    if (!isOpen) {
      body.classList.add('open');
      header.querySelector('.chevron').classList.add('open');
      header.setAttribute('aria-expanded', 'true');
    }
  };

  header.addEventListener('click', toggle);
  header.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });

  block.appendChild(header);
  block.appendChild(body);
  container.appendChild(block);
});
</script>

</body>
</html>
