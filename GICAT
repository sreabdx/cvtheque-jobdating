    "Supply Chain": "https://www.dropbox.com/request/el00qwqd8vhmoks6qc5g",
    "Commerce & Management": "https://www.dropbox.com/request/q8gf1l3r5od7d3358d85",
    "Data": "https://www.dropbox.com/request/npi12rc7ghwenfuwptw2",
    "IT & Développement web": "https://www.dropbox.com/request/n2awv1pyb61kvd5u5z3g",
